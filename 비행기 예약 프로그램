#include <iostream>
using namespace std;

int main() {
    int menu, area, line, number, newarea, newline, newnumber, i, j, k;
    int seats[3][4][6] = { 0 };  // 배열을 선언할 때 0으로 다 초기화를 함.
    int adult = 0, child = 0;
    int total = 0;
    int changeCount;

    while (1) {       // 무한 루프
        cout << "**비행기 예약 시스템**" << "\n";
        cout << "1.좌석 예약" << "\n";
        cout << "2.좌석 변경" << "\n";
        cout << "3.프로그램 종료" << "\n";

        cout << "번호를 입력하세요 : ";  // 번호 1,2,3번 중 하나를 입력받음
        cin >> menu;    // 번호를 입력받는 변수를 menu라고 설정
        cout << "\n";

        if (menu == 1) {  // 만약 menu에서 1을 입력받을 경우
            for (i = 0; i < 3; i++) {    // 좌석표를 먼저 보여줘야됨. i를 0부터 3번 반복 (구역이 3개이기 때문)
                cout << "1 2 3   4 5 6 (" << i + 1 << "구역)" << "\n";   // i는 0부터 시작하므로 i라고 적으면 0구역부터 2구역까지 3개의 구역이 만들어짐. 따라서 i + 1을 사용
                cout << "-------------" << "\n";  // 줄 구분선

                for (j = 0; j < 4; j++) {    // 좌석표가 4줄에 6칸씩 총 세 구역이다.
                    for (k = 0; k < 6; k++) {    // 가로로 여섯 칸이므로 0부터 6개
                        cout << seats[i][j][k] << " ";  // 구역(area)이 세 개, 열(line)이 한 구역 당 네 개, 한 줄 당 여섯 칸의 좌석(number)
                        if (k == 2)    
                            cout << " ";    // k가 0,1,2 총 세 개를 채운 후에 공백을 넣는다.
                    }
                    cout << "\n";
                }
                cout << "\n";
            }

            cout << "성인(50000원): ";
            cin >> adult;   // 입력받은 성인의 수는 adult로 선언
            cout << "유아(40000원): ";
            cin >> child;  // 입력받은 유아의 수는 child로 선언
            total = adult + child;  // 좌석의 개수만큼 예약해야 하므로 총 인원 수를 받아야 함.

            for (i = 0; i < total; ) {   // 0부터 total만큼 좌석 입력을 받는다.
                cout << "어떤 구역을 예약 하시겠습니까?" << "\n";
                cin >> area;  // 구역은 area

                if (area < 1 || area > 3) {   // 1,2,3구역 밖에 없는데 1,2,3을 제외한 다른 수를 입력받을 시 1보다 작거나 3보다 크면 (or 사용)
                    cout << "예약가능한 구역이 아닙니다." << "\n";  // ㄴ예약가능한 구역이 아니라고 출력
                    continue;  // 올바른 값(1,2,3)이 입력될 때까지 계속 입력을 받음.
                }

                cout << "몇열, 몇번째 좌석을 예약하시겠습니까?" << "\n";  // 구역이 정상적으로 입력을 받았다면 line과 number을 입력 받아야 함.
                cin >> line >> number;   // line 먼저 받고 number을 입력 받음

                if (line < 1 || line > 4 || number < 1 || number > 6) {   // 총 4열까지 있는데 1보다 작거나 4보다 클 시, 좌석 번호가 1보다 작거나 6보다 클 시
                    cout << "예약가능한 좌석이 아닙니다." << "\n";              // ㄴ 예약가능한 좌석이 아니라고 출력
                    continue;     // 또한 정상적인 숫자를 입력받을 때까지 continue
                }

                if (seats[area - 1][line - 1][number - 1] == 1) {      // 구역과 좌석 열, 번호가 이미 1로 예약되어 있을 시
                    cout << "이미 예약되었습니다. 다른 좌석을 선택하세요" << "\n";                           // ㄴ 선택할 수 없다는 멘트 출력
                    continue; // 좌석이 1이 아닌 곳을 선택할 때까지 continue
                }

                seats[area - 1][line - 1][number - 1] = 1; // 선택한 좌석은 0에서 1로 바뀌어야 함. -1을 하는 이유는 배열은 항상 0에서부터 시작하기 때문에 배열 기준으로 코드를 짜야 함.
                cout << "예약되었습니다." << "\n";  // 0에서 1로 바꾼 뒤 예약처리를 함.
                i++;
            }

            cout << "\n";
            for (i = 0; i < 3; i++) {
                cout << "1 2 3   4 5 6 (" << i + 1 << "구역)" << "\n";
                cout << "-------------" << "\n";     // 예약을 하고 나서 예약한 자리는 1로 바꾼 뒤 다시 좌석표를 보여줘야 함.

                for (j = 0; j < 4; j++) {
                    for (k = 0; k < 6; k++) {
                        cout << seats[i][j][k] << " ";
                        if (k == 2)
                            cout << " ";        // 아까와 똑같은 방식으로 좌석표를 출력
                    }
                    cout << "\n";
                }
                cout << "\n";
            }
        }

        else if (menu == 2) {    // 만약 메뉴에서 2번(좌석 변경)을 선택했을 경우
            for (i = 0; i < 3; i++) {
                cout << "1 2 3   4 5 6 (" << i + 1 << "구역)" << "\n";
                cout << "-------------" << "\n";   // 우선 좌석표의 배열을 출력함

                for (j = 0; j < 4; j++) {
                    for (k = 0; k < 6; k++) {
                        cout << seats[i][j][k] << " ";
                        if (k == 2)
                            cout << " ";
                    }
                    cout << "\n";
                }
                cout << "\n";
            }

            cout << "바꿀 좌석의 갯수를 입력하세요 : ";  // 좌석표 제시 후 입력받음.
            cin >> changeCount;  // 바꿀 좌석의 갯수를 changeCount로 저장함.

            for (i = 0; i < changeCount; ) {     // 0부터 changeCount만큼 반복 (만약 1을 입력하면 한 번 반복, 2를 입력하면 두 번 반복을 하게끔 설정되어 있음.)
                cout << "현재 좌석과 바꿀 좌석을 입력하세요" << "\n";

                cout << "현재 좌석(H구역, N열, M번째): ";
                cin >> area >> line >> number;       // 기존의 자리의 변수

                cout << "변경 좌석(H구역, N열, M번째): ";
                cin >> newarea >> newline >> newnumber;   // 변경하는 자리들의 변수

                if (area < 1 || area > 3 || line < 1 || line > 4 || number < 1 || number > 6 ||    // 구역은 1이상 3이하, 열은 1이상 4이하, 번호는 1이상 6이하여야 하므로 조건 달아줌.
                    newarea < 1 || newarea > 3 || newline < 1 || newline > 4 || newnumber < 1 || newnumber > 6) {
                    cout << "좌석 번호를 다시 입력해주세요" << "\n";
                    continue;
                }

                if (seats[area - 1][line - 1][number - 1] == 0) {  // 현재 좌석은 1로 바꾸어진 상태이므로 ==0 이라면 틀린 값임
                    cout << "현재 좌석이 틀렸습니다. 다시 입력해주세요" << "\n";  // 따라서 이렇게 출력함
                    continue; // 1의 값인 좌석이 나올 때까지 입력받음
                }

                if (area == newarea && line == newline && number == newnumber) {  // 좌석변경이므로 현재 좌석과 같으면 안 됨.
                    cout << "똑같은 좌석 입니다. 다른 좌석을 선택하세요" << "\n";  // ㄴ 따라서 만약 같다면 이렇게 출력함.
                    continue;
                }

                if (seats[newarea - 1][newline - 1][newnumber - 1] == 1) {    // 새로운 좌석이 1의 값을 가지고 있다면 이미 예약된 좌석이므로
                    cout << "이미 예약되었습니다. 다른 좌석을 선택하세요" << "\n";  // ㄴ 안내 문구가 뜬다.
                    continue;
                }

                seats[area - 1][line - 1][number - 1] = 0;  // 좌석 변경이 성공했다면 원래 좌석은 1에서 다시 0으로 바꿔야 함
                seats[newarea - 1][newline - 1][newnumber - 1] = 1;  // 새롭게 변경한 좌석은 0에서 1로 바꾸어야 함

                cout << "변경되었습니다." << "\n";   // 좌석 정보를 업데이트하고 변경되었다는 문구를 출력함
                i++;  // 반복이기 때문에 존재해야 함, 그래야 다음 수행을 반복하기 때문
            }

            cout << "\n";  // 적용된 좌석표의 배열을 다시 출력함.
            for (i = 0; i < 3; i++) {
                cout << "1 2 3   4 5 6 (" << i + 1 << "구역)" << "\n";
                cout << "-------------" << "\n";

                for (j = 0; j < 4; j++) {
                    for (k = 0; k < 6; k++) {
                        cout << seats[i][j][k] << " ";
                        if (k == 2)
                            cout << " ";
                    }
                    cout << "\n";
                }
                cout << "\n";
            }
        }

        else if (menu == 3) {  // menu에서 3번을 입력받았을 시
            cout << "총 " << adult * 50000 + child * 40000 << "원 입니다." << "\n";  // 총 가격을 출력
            break;        // 3번을 입력받으면 총 가격을 출력하고 프로그램을 종료한다.
        }

        else {
            cout << "잘못 입력했습니다." << "\n";   // menu에서 1,2,3 이외의 수가 입력됐을 시에 출력되는 문자열
        }
    }

    return 0;
}
