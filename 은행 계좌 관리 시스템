#include <iostream>
#include <string>
using namespace std;

// 메뉴를 화면에 보여주는 함수
void menu() {    // 이름이 menu인 함수
    cout << "============ 은행 계좌 관리 시스템 ============" << "\n";
    cout << "1. 현재 등록된 계좌 리스트 보기" << "\n";
    cout << "2. 신규 계좌 등록" << "\n";
    cout << "3. 입금 및 출금" << "\n";
    cout << "4. 계좌 간 이체" << "\n";
    cout << "5. 프로그램 종료" << "\n";
    cout << ">> 메뉴 선택 : ";    // 사용자에게 입력하라는 안내
}

// 입력한 이름과 같은 계좌가 몇 번째에 있는지 찾아주는 함수
// 찾으면 그 위치(index) 반환, 못 찾으면 -1 반환
int find(string names[], int count, string target) {
    // names 배열 안에서 총 count개 중에서 target을 찾는 함수
    // 반환값은 int (위치 번호)
    for (int i = 0; i < count; i++) {      // 0번부터 count -1까지 하나씩 확인
        if (names[i] == target)      // 만약 현재 이름이 찾는 이름과 같을 시
            return i;                // ㄴ 그 위치 (i)를 바로 돌려주고 종료
    }
    return -1;     // 끝까지 못 찾으면 -1 반환 (없다는 뜻임)
}

// 새 계좌를 추가하는 함수
// count는 참조(&)로 받아서 함수 안에서 바꾸면 main에서도 바로 바뀜
void add(string names[], int money[], int& count) {
    // names: 계좌 이름 배열
    // money: 잔액 배열
    // count: 현재 계좌 개수 (참조로 받아서 직접 수정이 가능함)
    string n;   // 새로 입력 받을 이름을 저장
    int m;      // 새로 입력 받을 초기 금액 저장

    cout << "\n" << "[신규 계좌 등록]" << "\n";   // 안내 메시지를 출력
    cout << "등록할 이름 : ";
    cin >> n;     // 사용자에게 이름 입력받기

    cout << "초기 잔액 : ";
    cin >> m;     // 사용자에게 초기 금액 입력 받아서 m으로 저장

    // 배열의 count번째 칸에 새 계좌 정보를 저장
    names[count] = n;    // 이름 저장
    money[count] = m;    // 금액 저장

    count++;  // 계좌 개수를 1 증가시킴 (참조라서 main에도 반영이 됨)

    cout << "신규 계좌 등록 완료했습니다." << "\n";
}

// 현재 저장된 모든 계좌를 화면에 출력하는 함수
void list(string names[], int money[], int count) {
    cout << "\n" << "-------- [현재 등록된 계좌 리스트] --------" << "\n";

    // 등록된 계좌가 하나도 없을 때 출력
    if (count == 0) {
        cout << "(등록된 계좌가 없습니다.)" << "\n";
        cout << "-------------------------------------------" << "\n";
        return;
    }

    // 0번부터 count-1번까지 저장된 계좌 정보 출력
    for (int i = 0; i < count; i++) {
        cout << i + 1 << ". 이름 : " << names[i] << "        | 잔액 : " << money[i] << "원" << "\n";
        // 번호, 이름, 잔액 출력
    }
    cout << "-------------------------------------------" << "\n";
}

// 입금 함수
// 포인터를 사용해서 실제 잔액(money 배열 값)을 바로 바꿈
void deposit(int* m, int amount) {
    *m += amount;
}

// 출금 함수
// 잔액이 충분하면 출금, 부족하면 실패
int withdraw(int* m, int amount) {
    // 출금하려는 금액이 현재 잔액보다 크면 출금 실패
    if (*m < amount)
        return 0;

    // 출금 성공 시 잔액에서 amount 빼기
    *m -= amount;
    return 1;  // 1 반환 -> 출금 성공
}

// 입금 또는 출금을 처리하는 함수
// 사용자가 선택한 계좌에 대해 작업을 수행함
void inout(string names[], int money[], int count) {

    string n;   // 조회할 계좌 이름을 입력 받을 변수
    int type;   // 입금인지 출금인지를 선택하는 변수
    int m;      // 입금이나 출금 금액을 입력 빋을 변수

    cout << "\n" << "조회할 이름을 입력하세요 : ";
    cin >> n;   // 사용자에게 계좌 이름을 입력받아 n에 저장

    int idx = find(names, count, n);    // 입력한 이름이 몇 번째 계좌인지 찾기

    // 계좌가 없으면 안내 후 함수 종료
    if (idx == -1) {
        cout << "존재하지 않는 사용자입니다." << "\n";
        return;     // 더 이상 진행 안 함
    }

    // 계좌가 존재하면 현재 잔액을 보여줌
    cout << "현재 " << names[idx] << "님의 잔액 : " << money[idx] << "원" << "\n";
    cout << "(1) 입금 | (2) 출금 : ";
    cin >> type;    // 입금 또는 출금 선택

    // 사용자가 입력한 번호가 1(입금) 또는 2(출금)가 맞는지 먼저 검사함
    if (type != 1 && type != 2) {
        cout << "올바른 번호를 입력하세요 (1 또는 2)." << "\n";
        return;     // 잘못된 번호면 함수 종료
    }

    cout << "거래 금액 입력 : ";
    cin >> m;      // 입금이나 출금 금액을 입력

    if (type == 1) {    // 입금 선택 시
        deposit(&money[idx], m);    // deposit 함수를 호출, 실제 잔액 증가
        cout << m << "원 입금 완료했습니다." << "\n";
    }
    else {      // 출금 선택 시
        if (withdraw(&money[idx], m))      // 출금에 성공하면
            cout << m << "원 출금 완료했습니다." << "\n";
        else     // 출금 실패하면 잔액 부족 안내
            cout << "잔액이 부족합니다." << "\n";
    }
}

// 한 계좌에서 다른 계좌로 돈을 보내는 함수
void move(string names[], int money[], int count) {

    string from;
    string to;
    int m;

    cout << "\n" << "[계좌 간 이체]" << "\n";
    cout << "보내는 분 이름 : ";
    cin >> from;

    cout << "받는 분 이름 : ";
    cin >> to;

    cout << "이체할 금액 : ";
    cin >> m;

    // 보내는 사람과 받는 사람의 배열 위치(index) 찾기
    int f = find(names, count, from);   // 보내는 사람 위치
    int t = find(names, count, to);     // 받는 사람 위치

    // 보내는 사람 또는 받는 사람이 존재하지 않으면 종료
    if (f == -1 || t == -1) {
        cout << "존재하지 않는 사용자입니다." << "\n";
        return;     // 함수 종료
    }

    // 보내는 사람의 잔액이 이체 금액보다 적으면 종료
    if (money[f] < m) {
        cout << "잔액이 부족합니다." << "\n";
        return;     // 함수 종료
    }

    // 보내는 사람 잔액 감소, 받는 사람 잔액 증가
    money[f] -= m;     // 보내는 사람 돈 빼기
    money[t] += m;     // 받는 사람 돈 더하기

    cout << "이체가 완료되었습니다." << "\n";  // 완료 안내
}

int main() {
    string names[100]; // 계좌 주인의 이름을 저장하는 배열 (최대 100개의 계좌 가능)
    int money[100];    // 각 계좌의 잔액을 저장하는 배열
    int count = 0;     // 현재 등록된 계좌 개수

    int sel;           // 사용자가 선택한 메뉴 번호

    // 프로그램을 계속 반복 실행 (사용자가 5번을 선택할 때까지)
    while (1) {
        menu();     // 메뉴 화면 출력
        cin >> sel;     // 사용자에게 메뉴 번호를 입력받아 sel에 저장

        // 1번: 계좌 목록 보기
        if (sel == 1)
            list(names, money, count);

        // 2번: 새 계좌 등록
        else if (sel == 2)
            add(names, money, count);

        // 3번: 입금/출금
        else if (sel == 3)
            inout(names, money, count);

        // 4번: 계좌 이체
        else if (sel == 4)
            move(names, money, count);

        // 5번: 프로그램 종료
        else if (sel == 5) {
            cout << "프로그램을 종료합니다." << "\n";
            break;      // while문 종료
        }

        // 1~5 이외의 숫자를 입력했을 때의 안내
        else
            cout << "올바른 번호를 입력해주세요." << "\n";

        cout << endl;
    }

    return 0;  // 프로그램 종료
} 
